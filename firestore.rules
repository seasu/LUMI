rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // User profile document: uid, email, plan, analyzedCount, freeQuota, etc.
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // All subcollections (wardrobe, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }
  }
}
